# Required: generate with `openssl rand -base64 32`.
MASTER_KEY=

# Optional defaults.
CHECK_INTERVAL_MINUTES=5
REDEEM_LEAD_MINUTES=10

# Optional: isolate state when deliberately sharing one Redis database.
# Never change this after setup.
# STATE_NAMESPACE=my-deployment

# Upstash Redis and QStash variables are injected by their Vercel integrations.
